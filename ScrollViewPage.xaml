<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeamRing.ScrollViewPage"
             Title="ScrollView"
             BackgroundColor="#F7F7F7">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="ScrollView"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#111111" />

            <Border BackgroundColor="White" Stroke="#E5E5E5" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="Simple card 1" TextColor="#222222" />
            </Border>

            <Border BackgroundColor="White" Stroke="#E5E5E5" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="Simple card 2" TextColor="#222222" />
            </Border>

            <Border BackgroundColor="White" Stroke="#E5E5E5" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="Simple card 3" TextColor="#222222" />
            </Border>

            <Border BackgroundColor="White" Stroke="#E5E5E5" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="Simple card 4" TextColor="#222222" />
            </Border>

            <Border BackgroundColor="White" Stroke="#E5E5E5" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label Text="Simple card 5" TextColor="#222222" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>